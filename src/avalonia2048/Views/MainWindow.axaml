<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:avalonia2048.ViewModels"
        xmlns:views="using:avalonia2048.Views"
        x:Class="avalonia2048.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="2048"
        Width="520"
        Height="660"
        MinWidth="480"
        MinHeight="600"
        Background="#faf8ef">

    <views:MainView DataContext="{Binding}"/>
</Window>
